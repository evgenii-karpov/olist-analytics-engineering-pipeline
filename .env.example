# AWS
AWS_PROFILE=default
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
OLIST_S3_BUCKET=replace-me
OLIST_S3_PREFIX=olist
REDSHIFT_COPY_IAM_ROLE_ARN=arn:aws:iam::<account-id>:role/replace-me

# Redshift
REDSHIFT_HOST=replace-me
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=dev
REDSHIFT_USER=replace-me
REDSHIFT_PASSWORD=replace-me

# Pipeline defaults
OLIST_BATCH_DATE=2018-09-01
OLIST_LOOKBACK_DAYS=3
