# Optional AWS / Redshift settings.
# Fill these in only if you want to run the AWS/Redshift DAG.
# For the local DAG, you can leave all values below empty.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
# Set only for temporary STS/SSO credentials. Omit for long-lived access keys.
AWS_SESSION_TOKEN=
OLIST_S3_BUCKET=replace-me
OLIST_S3_PREFIX=olist
REDSHIFT_COPY_IAM_ROLE_ARN=arn:aws:iam::<account-id>:role/replace-me

# Redshift
REDSHIFT_HOST=replace-me
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=dev
REDSHIFT_USER=replace-me
REDSHIFT_PASSWORD=replace-me
